        "z": "tab_kiosk_inicio",
        "group": "ui_group_inicio_nav",
        "page": "",
        "ui": "",
        "name": "Vista previa inicio",
        "order": 1,
        "width": "4",
        "height": "0",
        "head": "",
        "format": "<template>\n  <div style=\"padding:10px;\">\n    <div style=\"font-size:16px;font-weight:700;margin-bottom:10px;\">Vista previa</div>\n    <div style=\"font-size:13px;color:#666;margin-bottom:10px;\">Aquí se mostrará el payload del inicio de turno.</div>\n    <pre style=\"white-space:pre-wrap;font-size:12px;background:#f7f7f7;padding:10px;border-radius:8px;border:1px solid #ddd;\">{{ msg.payload ? JSON.stringify(msg.payload, null, 2) : 'Sin envío todavía.' }}</pre>\n  </div>\n</template>",
        "storeOutMessages": true,
        "passthru": false,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 780,
