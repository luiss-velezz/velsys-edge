    {
        "id": "fn_kiosk_inicio_preview",
        "type": "function",
        "z": "tab_kiosk_inicio",
        "name": "Vista previa inicio",
        "func": "const p = msg.payload || {};\nmsg.payload = {\n  evento: 'inicio_turno',\n  operador: p.operador || '',\n  pin: p.pin ? '••••' : '',\n  turno: p.turno || '',\n  area: p.area || '',\n  observaciones: p.observaciones || '',\n  fecha_hora_vista_previa: new Date().toISOString(),\n  estado: 'solo_frontend'\n};\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 510,
        "y": 280,
        "wires": [
            [
                "ui_template_kiosk_inicio",
                "debug_kiosk_inicio"
            ]
        ]
    },
    {
        "id": "ui_template_kiosk_inicio",
