    {
        "id": "a825884854b3bc79",
        "type": "function",
        "z": "0da54e05378d8da6",
        "g": "2a05c8f44d5e3b76",
        "name": "function 2",
        "func": "let drives = msg.payload;\n\nlet disk = drives.find(d =>\n    d.mount === \"/data\" ||\n    d.filesystem.includes(\"mmcblk\")\n);\n\nif (!disk) {\n    return null;\n}\n\nmsg.topic = \"disk_percent\";\nmsg.payload = Number((disk.capacity * 100).toFixed(1));\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 640,
